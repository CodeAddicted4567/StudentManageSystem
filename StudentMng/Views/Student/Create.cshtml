@model StudentMng.Models.Student

@{
    ViewBag.Title = "Create";
}
<h2>Create</h2>
@using (Html.BeginForm("Create", "Student", FormMethod.Post))
{
    @Html.AntiForgeryToken()
<div class="input-group">
    <label>Name</label>
    @Html.TextBoxFor(m => m.Name)
    @Html.ValidationSummary(true, "Incorrect information", new { @class = "text-danger" })
</div>

<div class="input-group">
    <label>Marks</label>
    @Html.TextBoxFor(m => m.Marks)
    @Html.ValidationSummary(true, "Incorrect information", new { @class = "text-danger" })

</div>
    <br />
    <button class="btn btn-primary" type="submit">Save</button>
    @Html.ValidationSummary(true, "Failed to creation an Entity", new { @class = "text-danger" })
}

